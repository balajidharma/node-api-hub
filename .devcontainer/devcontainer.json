{
    "name": "NodeAPIHubDevContainer",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "node.test",
    "workspaceFolder": "/app",
    "features": {},
    "customizations": {
        "vscode": {
            "extensions": [
                "humao.rest-client",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "nrwl.angular-console",
                "firsttris.vscode-jest-runner"
            ]
        }
    },
    "remoteEnv": {
        "NX_DAEMON": "true"
    },
    "remoteUser": "root"
}
